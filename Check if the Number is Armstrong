class Solution {
    public boolean isArmstrong(int n) {
        int oriNum = n;
        int sum = 0;
        int power = countDigits(n);
        while(n > 0){
            int digit = n%10;
            sum += Math.pow(digit, power);
            n = n/10;    
        }
        if(oriNum == sum) return true;
        return false;

    }
    private int countDigits(int n){
        int count = 0;
        while(n > 0){
            n /= 10;
            count++;
        }
        return count;
    }

}
