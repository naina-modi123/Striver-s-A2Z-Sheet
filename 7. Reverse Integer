class Solution {
    public int reverse(int x) {
        if(x < 0){
            x = x*-1;
            return helper(x) * -1;
        }
        return helper(x);
    }
    public int helper(int x){
        int revNum = 0;
        while(x > 0){
            int lastDigit = x % 10;
            revNum = (revNum * 10)+lastDigit;
            x = x/10;
        }
        return revNum;
    }
}
